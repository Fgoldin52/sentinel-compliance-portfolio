---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/sections/Hero.astro';
import TrustStrip from '@/components/sections/TrustStrip.astro';
import Problem from '@/components/sections/Problem.astro';
import ProductPillars from '@/components/sections/ProductPillars.astro';
import Proof from '@/components/sections/Proof.astro';
import RegulatoryAlignment from '@/components/sections/RegulatoryAlignment.astro';
import Integrations from '@/components/sections/Integrations.astro';
import Security from '@/components/sections/Security.astro';
import Resources from '@/components/sections/Resources.astro';
import FinalCTA from '@/components/sections/FinalCTA.astro';
import Footer from '@/components/sections/Footer.astro';
---

<Layout
    title="Sentinel Compliance — AML transaction monitoring for mid-sized banks"
    description="Sentinel cuts alert volume by 40–60% in the first 90 days while preserving the audit trail your examiners read first. Built for BSA teams at regional and community banks."
>
    <main id="main-content" tabindex="-1">
        <Hero />
        <TrustStrip />
        <Problem />
        <ProductPillars />
        <Proof />
        <RegulatoryAlignment />
        <Integrations />
        <Security />
        <Resources />
        <FinalCTA />
    </main>
    <Footer />
</Layout>
