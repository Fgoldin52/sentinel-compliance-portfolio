---
import { buttonVariants } from '@/components/ui/button';
---

<section aria-labelledby="final-cta-heading">
    <div class="mx-auto max-w-[1280px] px-6 pt-24 pb-0 sm:px-8 sm:pt-28 lg:px-12 lg:pt-32">
        {/* Top hairline + oxblood eyebrow */}
        <div class="border-t border-rule pt-4">
            <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-oxblood sm:text-xs">
                A 30-minute walkthrough
            </p>
        </div>

        {/* H2 — three-fragment declarative, forced sentence breaks for cadence */}
        <h2
            id="final-cta-heading"
            class="mt-12 font-serif font-medium text-ink text-3xl leading-[1.1] tracking-[-0.02em] text-balance sm:text-5xl lg:mt-16 lg:text-[3.5rem]"
        >
            Thirty minutes.<br />
            A former BSA officer.<br />
            Your questions.
        </h2>

        {/* Primary CTA — same buttonVariants pattern as Hero */}
        <div class="mt-12 lg:mt-16">
            <a
                href="/request-demo"
                class={buttonVariants({ variant: 'default', className: 'h-11 px-6 text-sm rounded-sm' })}
            >
                Schedule a walkthrough
                <span aria-hidden="true">&rarr;</span>
            </a>
        </div>

        {/* Italic coda — reinforces the role-credibility claim with concrete specificity */}
        <p class="mt-10 max-w-[60ch] font-serif italic text-base leading-[1.5] text-ink/65 sm:mt-12 sm:text-lg">
            &mdash; Walkthroughs are conducted by people who have run BSA programs at regional banks.
        </p>

        {/* Bottom hairline — full sealing as closure signal */}
        <div class="mt-16 border-t border-rule sm:mt-20 lg:mt-24"></div>
    </div>
</section>
