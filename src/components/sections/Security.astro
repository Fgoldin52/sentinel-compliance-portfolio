---
const groupings = [
    {
        label: 'Deployment',
        rows: [
            ['Topology', 'Multi-tenant SaaS · Dedicated · BYOC · On-prem'],
            ['Regions', 'US-only by default · customer-selectable for dedicated and BYOC'],
            [
                'Migration',
                'No replatform required · 4–6 weeks median to production for multi-tenant',
            ],
        ],
    },
    {
        label: 'Encryption & keys',
        rows: [
            ['In transit', 'TLS 1.3 minimum · mutual TLS for upstream feeds'],
            [
                'At rest',
                'AES-256 · BYOK via AWS KMS, GCP KMS, or customer-managed HSM',
            ],
            ['Secrets', 'Vault-backed · no plaintext credentials at rest'],
        ],
    },
    {
        label: 'Access & audit',
        rows: [
            ['Authentication', 'SAML 2.0, OIDC · MFA required for all roles'],
            ['Authorization', 'RBAC with row-level segmentation'],
            [
                'Audit logs',
                'Immutable · exportable to bank SIEM via syslog or webhook',
            ],
        ],
    },
    {
        label: 'Attestations',
        rows: [
            ['SOC 2 Type II', 'Audited annually · most recent report: 2026-Q1'],
            ['ISO 27001', 'Certified · scope statement on request'],
            [
                'Penetration',
                'Annually, independent third-party · most recent: 2026-Q1',
            ],
        ],
    },
    {
        label: 'Incident response',
        rows: [
            ['Notification', '24-hour customer disclosure · contractual SLA'],
            ['Vuln disclosure', '90-day SLO for high severity · 30-day for critical'],
            [
                'RPO / RTO',
                '15 min / 4 hr (multi-tenant) · 1 min / 30 min (dedicated)',
            ],
        ],
    },
];
---

<section aria-labelledby="security-heading">
    <div class="mx-auto max-w-[1280px] px-6 py-20 sm:px-8 sm:py-24 lg:px-12 lg:py-28">
        {/* Top hairline + oxblood eyebrow */}
        <div class="border-t border-rule pt-4">
            <p class="font-mono text-[11px] uppercase tracking-[0.14em] text-oxblood sm:text-xs">
                On the security review
            </p>
        </div>

        {/* H2 */}
        <h2
            id="security-heading"
            class="mt-10 font-serif font-medium text-ink text-3xl leading-[1.15] tracking-[-0.01em] text-balance sm:text-4xl lg:mt-12 lg:text-[2.75rem]"
        >
            Built for the security review you&rsquo;ve already done.
        </h2>

        {/* Italic sub-deck */}
        <p class="mt-4 max-w-[58ch] font-serif italic text-xl leading-[1.4] text-ink/75 text-balance sm:text-2xl">
            Your choice of deployment, your choice of region, your keys.
        </p>

        {/* Spec sheet — 5 groupings, hairline-separated */}
        <div class="mt-12 sm:mt-16 lg:mt-20">
            {groupings.map((group) => (
                <div class="border-t border-rule py-8 sm:py-10">
                    <p class="mb-5 font-mono text-xs uppercase tracking-[0.14em] text-ink sm:mb-6">
                        {group.label}
                    </p>
                    <dl class="grid grid-cols-1 lg:grid-cols-[12rem_1fr] lg:gap-x-8 lg:gap-y-3.5">
                        {group.rows.map(([label, value], i) => (
                            <Fragment>
                                <dt
                                    class:list={[
                                        'font-mono text-xs uppercase tracking-wider text-muted-foreground lg:pt-0.5',
                                        i > 0 && 'mt-4 lg:mt-0',
                                    ]}
                                >
                                    {label}
                                </dt>
                                <dd class="mt-1 font-serif text-[15px] leading-[1.55] text-ink text-pretty sm:text-base lg:mt-0">
                                    {value}
                                </dd>
                            </Fragment>
                        ))}
                    </dl>
                </div>
            ))}
        </div>
    </div>
</section>
